{
  "name": "storm-response-commander",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev:server": "ts-node-dev --project tsconfig.node.json --respawn src/server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "heroku-postbuild": "npm run build",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.5"
  }
}
